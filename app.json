{
  "expo": {
    "name": "GPS Camera",
    "slug": "GPS_Camera",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gpscamera",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "GPS Camera needs camera access to capture site investigation photos.",
        "NSLocationWhenInUseUsageDescription": "GPS Camera needs your location to embed GPS coordinates into site photos.",
        "NSPhotoLibraryAddUsageDescription": "GPS Camera saves geo-tagged site photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/favicon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.adityakumar5155.GPS_Camera"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GPS Camera needs your location to embed GPS coordinates in site investigation photos.",
          "locationAlwaysAndWhenInUsePermission": "GPS Camera needs your location to embed GPS coordinates in site investigation photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "GPS Camera saves captured site photos with GPS overlay to your gallery.",
          "savePhotosPermission": "GPS Camera saves captured site photos with GPS overlay to your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0f",
          "dark": {
            "backgroundColor": "#0a0a0f"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9227de5a-4248-4bf0-a247-82a742382f17"
      }
    }
  }
}
